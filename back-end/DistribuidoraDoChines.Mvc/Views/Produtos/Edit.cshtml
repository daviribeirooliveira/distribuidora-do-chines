@model DistribuidoraDoChines.Commons.Models.Produtos

@{
    ViewData["Title"] = "Edit";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Editar</h1>

<h4>Produtos</h4>
<hr/>
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id"/>
            <div class="form-group">
                <label asp-for="IdCategoria" class="control-label">Categoria</label>
                <select asp-for="IdCategoria" class="form-control" asp-items="ViewBag.IdCategoria"></select>
                <span asp-validation-for="IdCategoria" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Nome" class="control-label"></label>
                <input asp-for="Nome" class="form-control"/>
                <span asp-validation-for="Nome" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Preco" class="control-label"></label>
                <input asp-for="PrecoEmReais" type="number" step=".01" class="form-control"/>
                <span asp-validation-for="Preco" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input asp-for="Preco" hidden/>
            </div>
            <div class="form-group">
                <label asp-for="Unidade" class="control-label"></label>
                <input asp-for="Unidade" type="checkbox"/>
                <span asp-validation-for="Unidade" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Status" class="control-label"></label>
                <input asp-for="Status" type="checkbox"/>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>
            <div class="custom-file">
                <label asp-for="Imagem" class="control-label"></label>
                <label asp-for="Imagem" class="custom-file-label">Escolha o arquivo...</label>
                <input asp-for="Imagem" type="file" accept="image/png" hidden>
            </div>
            <div class="form-group">
                <input asp-for="ImagemBlob" hidden/>
            </div>
            <div class="form-group">
                <input asp-for="CreatedAt" type="hidden"/>
            </div>
            <div class="form-group">
                <input type="submit" value="Salvar" class="btn btn-primary"/>
            </div>
        </form>
    </div>
    <div class="col-md-4">
    </div>
    <div class="col-md-4">
        <div class="form-group">
            @if (Model.ImagemBlob != null)
            {
                <img src=" data:image/png;charset=utf-8;base64,@Model.ImagemBlob" class="rounded" height="240" width="240" alt=""/>
            }
        </div>
    </div>
</div>

<div>
    <a asp-action="Index">Voltar</a>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}