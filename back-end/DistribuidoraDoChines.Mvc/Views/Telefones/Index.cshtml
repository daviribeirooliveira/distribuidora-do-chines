@model DistribuidoraDoChines.Commons.Models.PaginatedList<DistribuidoraDoChines.Commons.Models.Telefones>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Telefones</h1>

<p>
    <a asp-action="Create">Criar</a>
</p>

<form asp-controller="Telefones" asp-action="Index" method="get" class="form-inline">
    <div class="form-group mx-sm-8 mb-2">
        <input type="text" name="searchString" placeholder="Cliente ou Número..." class="form-control">
    </div>
    <button type="submit" class="btn btn-primary mb-2">Buscar</button>
</form>

<table class="table">
    <thead>
    <tr>
        <th>
            <a asp-action="Index" asp-route-sortOrder="@ViewData["ClienteSortParm"]" asp-route-currentFilter="@ViewData["CurrentFilter"]">Cliente</a>
        </th>
        <th>
            <a asp-action="Index" asp-route-sortOrder="@ViewData["CelularSortParm"]" asp-route-currentFilter="@ViewData["CurrentFilter"]">Celular</a>
        </th>
        <th>
            <a asp-action="Index" asp-route-sortOrder="@ViewData["ResidencialSortParm"]" asp-route-currentFilter="@ViewData["CurrentFilter"]">Residencial</a>
        </th>
        <th>
            <a asp-action="Index" asp-route-sortOrder="@ViewData["ComercialSortParm"]" asp-route-currentFilter="@ViewData["CurrentFilter"]">Comercial</a>
        </th>
        <th>
            Ações
        </th>
        <th></th>
    </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.IdClienteNavigation.Email)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Celular)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Residencial)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Comercial)
            </td>
            <td>
                <a asp-action="FindCliente" asp-route-IdCliente="@item.IdCliente">Cliente</a>
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Editar</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Detalhes</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Deletar</a>
            </td>
        </tr>
    }
    </tbody>
</table>

@{
    var prevDisabled = !Model.HasPreviousPage ? "disabled" : "";
    var nextDisabled = !Model.HasNextPage ? "disabled" : "";
}

<a asp-action="Index"
   asp-route-sortOrder="@ViewData["CurrentSort"]"
   asp-route-pageNumber="@(Model.PageIndex - 1)"
   asp-route-currentFilter="@ViewData["CurrentFilter"]"
   class="btn btn-default @prevDisabled">
    Anterior
</a>
<a asp-action="Index"
   asp-route-sortOrder="@ViewData["CurrentSort"]"
   asp-route-pageNumber="@(Model.PageIndex + 1)"
   asp-route-currentFilter="@ViewData["CurrentFilter"]"
   class="btn btn-default @nextDisabled">
    Próximo
</a>